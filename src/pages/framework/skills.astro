---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Skills — Capitaliser les savoirs experts" description="Transformer les savoirs experts tacites en actifs IA permanents. IP métier, skills Claude, démarche en 3 étapes.">

  <section class="bg-gradient-to-br from-slate-900 to-slate-800 text-white py-20">
    <div class="max-w-3xl mx-auto px-6">
      <div class="mb-4">
        <a href={`${base}framework/`} class="text-slate-400 text-sm hover:text-slate-200 no-underline">← Framework</a>
      </div>
      <p class="text-sm font-bold tracking-widest uppercase text-blue-400 mb-4">Skills</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Capitaliser les savoirs experts en actifs IA</h1>
      <p class="text-slate-300 text-lg leading-relaxed">
        Dans la plupart des organisations, la connaissance la plus précieuse est orale. Un skill la transforme en actif permanent — utilisable, transmissible, maintenable.
      </p>
    </div>
  </section>

  <div class="max-w-3xl mx-auto px-6 py-16 space-y-14">

    <!-- Distinction marché -->
    <section>
      <h2 class="text-2xl font-bold text-slate-900 mb-6">Ce que le marché produit. Ce que cette offre produit.</h2>
      <div class="grid md:grid-cols-2 gap-5">
        <div class="rounded-xl p-6 border border-slate-200 bg-slate-50">
          <p class="text-xs font-bold uppercase tracking-wide text-slate-400 mb-3">Ce que le marché produit</p>
          <p class="text-slate-600 text-sm leading-relaxed">Des raccourcis de productivité — des prompts génériques, des templates réutilisables, des automatisations de surface.</p>
        </div>
        <div class="rounded-xl p-6 border border-blue-200" style="background:#eff6ff">
          <p class="text-xs font-bold uppercase tracking-wide text-blue-600 mb-3">Ce que cette offre produit</p>
          <p class="text-slate-700 text-sm leading-relaxed">Des <strong>IP métier</strong> — les critères de décision d'un expert, les 7 phases d'un diagnostic, le raisonnement d'un commercial senior. La différence n'est pas de degré. Elle est de nature.</p>
        </div>
      </div>
    </section>

    <!-- Ce que le client obtient -->
    <section>
      <h2 class="text-2xl font-bold text-slate-900 mb-4">Ce que le client obtient</h2>
      <p class="text-slate-700 text-base leading-relaxed">
        Un actif permanent qui reste dans l'organisation après la mission. Un expert part à la retraite : son raisonnement reste dans le système.
      </p>
    </section>

    <!-- Démarche -->
    <section>
      <h2 class="text-2xl font-bold text-slate-900 mb-8">La démarche en 3 étapes</h2>
      <div class="space-y-5">
        {[
          {
            num: '1',
            title: 'Faire parler l\'expert',
            desc: 'Entretien semi-directif, 60-90 min. Extraction du raisonnement implicite, des heuristiques, des critères de décision non formalisés.',
          },
          {
            num: '2',
            title: 'Structurer et valider',
            desc: 'Livrable MASK (Mission, Actions, Skills, Knowledge). Validation par l\'expert pour garantir la fidélité du raisonnement capturé.',
          },
          {
            num: '3',
            title: 'Créer et évaluer le skill',
            desc: 'Création du skill Claude. Évaluation sur jeu de cas réels. Objectif : pass rate ≥ 80% sur les cas de validation.',
          },
        ].map(step => (
          <div class="flex gap-5">
            <div class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center font-bold text-sm text-white" style="background:var(--primary-600)">{step.num}</div>
            <div class="pt-0.5">
              <h3 class="font-semibold text-slate-900 mb-1">{step.title}</h3>
              <p class="text-slate-600 text-sm leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Skill en production -->
    <section class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
      <p class="text-xs font-bold uppercase tracking-wide text-slate-400 mb-3">Skill en production</p>
      <p class="font-mono text-sm text-slate-700 mb-1"><code>knowledge-capitalization</code></p>
      <p class="text-slate-500 text-sm">v4 · 4 itérations · 80–100% pass rate</p>
    </section>

    <!-- CTA -->
    <section class="text-center">
      <a href="/contact/" class="btn-primary px-8 py-4 text-base">Nous contacter</a>
    </section>

  </div>

</Layout>
