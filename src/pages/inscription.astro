---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Créer un compte" description="Créez un compte gratuit pour sauvegarder votre progression dans la formation AI Practice Steward.">

  <section class="min-h-screen flex items-center justify-center px-4 py-16 bg-slate-50">
    <div class="w-full max-w-md">

      <div class="mb-6 text-center">
        <a href={base} class="inline-flex items-center gap-1 text-sm font-bold no-underline" aria-label="Retour à l'accueil">
          <span style="color:var(--primary-600)">Reflexe</span><span style="color:var(--accent-500)">IA</span>
        </a>
      </div>

      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-8">
        <h1 class="text-2xl font-bold text-slate-900 mb-1">Créer un compte</h1>
        <p class="text-slate-500 text-sm mb-6">Gratuit — pour sauvegarder votre progression.</p>

        <!-- Message contextuel (ex : redirection depuis /formation/) -->
        <div id="ctx-message" class="mb-5 rounded-lg bg-blue-50 border border-blue-200 px-4 py-3 text-sm text-blue-700" style="display:none"></div>

        <!-- Erreur globale -->
        <div id="form-error" class="mb-5 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700" style="display:none"></div>

        <!-- Message succès -->
        <div id="form-success" class="mb-5 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800" style="display:none"></div>

        <form id="signup-form" novalidate class="space-y-4">

          <div class="grid grid-cols-2 gap-3">
            <div>
              <label for="prenom" class="block text-sm font-medium text-slate-700 mb-1">Prénom <span class="text-red-500">*</span></label>
              <input type="text" id="prenom" name="prenom" required autocomplete="given-name"
                class="w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition" />
              <p class="field-error text-xs text-red-600 mt-1" style="display:none"></p>
            </div>
            <div>
              <label for="nom" class="block text-sm font-medium text-slate-700 mb-1">Nom <span class="text-red-500">*</span></label>
              <input type="text" id="nom" name="nom" required autocomplete="family-name"
                class="w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition" />
              <p class="field-error text-xs text-red-600 mt-1" style="display:none"></p>
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Email professionnel <span class="text-red-500">*</span></label>
            <input type="email" id="email" name="email" required autocomplete="email"
              class="w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition" />
            <p class="field-error text-xs text-red-600 mt-1" style="display:none"></p>
          </div>

          <div>
            <label for="entreprise" class="block text-sm font-medium text-slate-700 mb-1">Entreprise <span class="text-slate-400 font-normal">(optionnel)</span></label>
            <input type="text" id="entreprise" name="entreprise" autocomplete="organization"
              class="w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition" />
          </div>

          <div>
            <label for="password" class="block text-sm font-medium text-slate-700 mb-1">Mot de passe <span class="text-red-500">*</span></label>
            <input type="password" id="password" name="password" required autocomplete="new-password" minlength="8"
              class="w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition" />
            <p class="text-xs text-slate-400 mt-1">8 caractères minimum</p>
            <p class="field-error text-xs text-red-600 mt-1" style="display:none"></p>
          </div>

          <div>
            <label for="password-confirm" class="block text-sm font-medium text-slate-700 mb-1">Confirmer le mot de passe <span class="text-red-500">*</span></label>
            <input type="password" id="password-confirm" name="password-confirm" required autocomplete="new-password"
              class="w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition" />
            <p class="field-error text-xs text-red-600 mt-1" style="display:none"></p>
          </div>

          <div class="pt-1">
            <label class="flex items-start gap-3 cursor-pointer">
              <input type="checkbox" id="consent" name="consent" required
                class="mt-0.5 w-4 h-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500 flex-shrink-0" />
              <span class="text-sm text-slate-600 leading-relaxed">
                J'accepte les <a href="/cgu/" class="text-blue-600 hover:underline" target="_blank">CGU</a> et j'accepte d'être contacté par Reflexe IA pour des offres de formation ou d'accompagnement AI Practice Steward. <span class="text-red-500">*</span>
              </span>
            </label>
            <p id="consent-error" class="text-xs text-red-600 mt-1 ml-7" style="display:none">Ce champ est obligatoire.</p>
          </div>

          <button type="submit" id="submit-btn" class="btn-primary w-full justify-center py-3 mt-2">
            Créer mon compte
          </button>

        </form>

        <p class="text-center text-sm text-slate-500 mt-6">
          Déjà un compte ? <a href="/connexion/" class="text-blue-600 font-medium hover:underline">Se connecter</a>
        </p>
      </div>

    </div>
  </section>

</Layout>

<script>
  import { supabase } from '../lib/supabase';

  // Show contextual message if redirected from formation
  const params = new URLSearchParams(window.location.search);
  if (params.get('source') === 'formation') {
    const msg = document.getElementById('ctx-message');
    if (msg) {
      msg.textContent = 'Créez un compte gratuit pour sauvegarder votre progression.';
      msg.style.display = '';
    }
  }

  const form     = document.getElementById('signup-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const globalError   = document.getElementById('form-error')!;
  const globalSuccess = document.getElementById('form-success')!;

  function showGlobalError(msg: string) {
    globalError.textContent = msg;
    globalError.style.display = '';
    globalSuccess.style.display = 'none';
  }

  function clearGlobalMessages() {
    globalError.style.display = 'none';
    globalSuccess.style.display = 'none';
  }

  function fieldError(input: HTMLInputElement, msg: string) {
    input.classList.add('border-red-400');
    const errEl = input.nextElementSibling as HTMLElement;
    if (errEl?.classList.contains('field-error')) {
      errEl.textContent = msg;
      errEl.style.display = '';
    }
  }

  function clearFieldErrors() {
    document.querySelectorAll('.field-error').forEach(el => {
      (el as HTMLElement).style.display = 'none';
      (el as HTMLElement).textContent = '';
    });
    document.querySelectorAll('input').forEach(el => el.classList.remove('border-red-400'));
    const consentErr = document.getElementById('consent-error')!;
    consentErr.style.display = 'none';
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearFieldErrors();
    clearGlobalMessages();

    const prenom    = (document.getElementById('prenom') as HTMLInputElement).value.trim();
    const nom       = (document.getElementById('nom') as HTMLInputElement).value.trim();
    const email     = (document.getElementById('email') as HTMLInputElement).value.trim();
    const entreprise = (document.getElementById('entreprise') as HTMLInputElement).value.trim();
    const password  = (document.getElementById('password') as HTMLInputElement).value;
    const confirm   = (document.getElementById('password-confirm') as HTMLInputElement).value;
    const consent   = (document.getElementById('consent') as HTMLInputElement).checked;

    let hasError = false;

    if (!prenom) { fieldError(document.getElementById('prenom') as HTMLInputElement, 'Le prénom est obligatoire.'); hasError = true; }
    if (!nom)    { fieldError(document.getElementById('nom') as HTMLInputElement, 'Le nom est obligatoire.'); hasError = true; }
    if (!email)  { fieldError(document.getElementById('email') as HTMLInputElement, 'L\'email est obligatoire.'); hasError = true; }
    if (password.length < 8) { fieldError(document.getElementById('password') as HTMLInputElement, 'Le mot de passe doit contenir au moins 8 caractères.'); hasError = true; }
    if (password !== confirm) { fieldError(document.getElementById('password-confirm') as HTMLInputElement, 'Les mots de passe ne correspondent pas.'); hasError = true; }
    if (!consent) { document.getElementById('consent-error')!.style.display = ''; hasError = true; }

    if (hasError) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Création en cours…';

    const { data, error } = await supabase.auth.signUp({ email, password });

    if (error) {
      let msg = error.message;
      if (msg.includes('already registered') || msg.includes('User already registered')) {
        msg = 'Cet email est déjà utilisé. <a href="/connexion/" class="underline">Se connecter</a> ?';
        globalError.innerHTML = msg;
        globalError.style.display = '';
      } else {
        showGlobalError(msg);
      }
      submitBtn.disabled = false;
      submitBtn.textContent = 'Créer mon compte';
      return;
    }

    if (data.user) {
      await supabase.from('user_profiles').insert({
        id:              data.user.id,
        prenom,
        nom,
        entreprise:      entreprise || null,
        consent_contact: true,
      });
    }

    if (data.session) {
      window.location.href = '/formation/';
    } else {
      globalSuccess.textContent = 'Un email de confirmation a été envoyé. Cliquez sur le lien pour accéder à votre formation.';
      globalSuccess.style.display = '';
      form.style.display = 'none';
    }
  });
</script>
