---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
const sujet = Astro.url.searchParams?.get?.('sujet') ?? '';
---
<Layout title="Contact" description="Contactez Reflexe IA pour toute question sur la formation, un accompagnement ou une contribution au framework.">

  <section class="max-w-2xl mx-auto px-6 py-20">
    <div class="mb-6">
      <a href={base} class="text-slate-400 text-sm hover:text-slate-600 no-underline">← Accueil</a>
    </div>
    <h1 class="text-3xl font-bold text-slate-900 mb-3">Contact</h1>
    <p class="text-slate-500 text-base mb-10">
      Pour toute question sur la formation, une mission d'accompagnement ou une contribution au framework.
    </p>

    <div class="flex flex-wrap gap-6 mb-12 text-sm">
      <a href="mailto:contact@reflexe-ia.org" class="text-blue-600 hover:underline font-medium">contact@reflexe-ia.org</a>
      <span class="text-slate-400">reflexe-ia.org</span>
      <a href="https://fgitconseil.com" target="_blank" rel="noopener" class="text-slate-500 hover:text-blue-600">FGIT Conseil — fgitconseil.com</a>
    </div>

    <form
      action="mailto:contact@reflexe-ia.org"
      method="post"
      enctype="text/plain"
      class="space-y-6"
    >
      <div>
        <label for="nom" class="block text-sm font-medium text-slate-700 mb-2">Nom</label>
        <input
          type="text"
          id="nom"
          name="nom"
          required
          class="w-full px-4 py-3 rounded-lg border border-slate-200 text-slate-900 text-sm focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
          placeholder="Votre nom"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-slate-700 mb-2">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full px-4 py-3 rounded-lg border border-slate-200 text-slate-900 text-sm focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
          placeholder="votre@email.com"
        />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium text-slate-700 mb-2">Message</label>
        <textarea
          id="message"
          name="message"
          required
          rows="6"
          class="w-full px-4 py-3 rounded-lg border border-slate-200 text-slate-900 text-sm focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 resize-y"
          placeholder="Votre message..."
        ></textarea>
      </div>
      <button type="submit" class="btn-primary w-full justify-center py-3">
        Envoyer le message →
      </button>
    </form>
  </section>

</Layout>
