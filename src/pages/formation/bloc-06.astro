---
import Layout from '../../layouts/Layout.astro';
import SlidePlayer from '../../components/SlidePlayer.astro';
import { BLOCS, getSlidesForBloc, TAKEAWAY_URLS } from '../../lib/slideData';
const base = import.meta.env.BASE_URL;

const bloc = BLOCS.find(b => b.id === 'bloc-06')!;
const takeawayUrl = TAKEAWAY_URLS['bloc-06'];
const slides = getSlidesForBloc('bloc-06');
---
<Layout
  title={bloc.titre}
  description={bloc.desc}
>
  <section class="max-w-4xl mx-auto px-4 py-10">
    <div class="mb-6 flex items-center gap-2 text-sm text-slate-400">
      <a href={`${base}formation/`} class="hover:text-slate-600 no-underline">Formation</a>
      <span>›</span>
      <span class="text-slate-600">Bloc {bloc.ordre} — {bloc.titre}</span>
    </div>
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-2">
        <span class={`w-7 h-7 rounded-full ${bloc.phaseColor} text-white flex items-center justify-center font-bold text-xs`}>{bloc.ordre}</span>
        <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${bloc.tagColor}`}>{bloc.phase}</span>
        <span class="text-xs text-slate-400">{bloc.duree}</span>
      </div>
      <h1 class="text-2xl md:text-3xl font-bold text-slate-900">{bloc.titre}</h1>
      <p class="text-slate-500 text-sm mt-2">{bloc.desc}</p>
    </div>

    <SlidePlayer
      slides={slides}
      blocId="bloc-06"
      nextBlocTitle="Retour au parcours"
      nextBlocUrl={`${base}formation/`}
      takeawayUrl={takeawayUrl}
    />

    <!-- CTA post-formation -->
    <div class="mt-12 p-8 rounded-2xl bg-gradient-to-br from-slate-900 to-slate-800 text-white text-center">
      <p class="text-sm font-bold tracking-widest uppercase text-blue-400 mb-3">Prochaine étape</p>
      <h2 class="text-2xl font-bold mb-3">Devenir AI Practice Steward</h2>
      <p class="text-slate-300 text-sm leading-relaxed mb-6 max-w-md mx-auto">
        La formation vous donne la méthode. L'accompagnement vous aide à la déployer dans votre organisation.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href={`${base}ai-practice-steward/`} class="btn-secondary" style="color:white;border-color:rgba(255,255,255,0.3)">Découvrir le rôle</a>
        <a href="https://www.linkedin.com/company/reflexe-ia" target="_blank" rel="noopener" class="btn-primary">Nous contacter →</a>
      </div>
    </div>
  </section>
</Layout>
