---
import Layout from '../../layouts/Layout.astro';
import SlidePlayer from '../../components/SlidePlayer.astro';
import { BLOCS, getSlidesForBloc, TAKEAWAY_URLS } from '../../lib/slideData';
const base = import.meta.env.BASE_URL;

const bloc = BLOCS.find(b => b.id === 'bloc-02')!;
const next = BLOCS.find(b => b.ordre === bloc.ordre + 1);
const nextUrl = next ? `${base}formation/${next.id}/` : `${base}formation/`;
const slides = getSlidesForBloc('bloc-02');
const takeawayUrl = TAKEAWAY_URLS['bloc-02'];
---
<Layout
  title={bloc.titre}
  description={bloc.desc}
>
  <section class="max-w-4xl mx-auto px-4 py-10">
    <div class="mb-6 flex items-center gap-2 text-sm text-slate-400">
      <a href={`${base}formation/`} class="hover:text-slate-600 no-underline">Formation</a>
      <span>›</span>
      <span class="text-slate-600">Bloc {bloc.ordre} — {bloc.titre}</span>
    </div>
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-2">
        <span class={`w-7 h-7 rounded-full ${bloc.phaseColor} text-white flex items-center justify-center font-bold text-xs`}>{bloc.ordre}</span>
        <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${bloc.tagColor}`}>{bloc.phase}</span>
        <span class="text-xs text-slate-400">{bloc.duree}</span>
      </div>
      <h1 class="text-2xl md:text-3xl font-bold text-slate-900">{bloc.titre}</h1>
      <p class="text-slate-500 text-sm mt-2">{bloc.desc}</p>
    </div>

    <SlidePlayer
      slides={slides}
      blocId="bloc-02"
      nextBlocUrl={nextUrl}
      nextBlocTitle={next?.titre}
      takeawayUrl={takeawayUrl}
    />
  </section>
</Layout>
